<Application x:Class="CodexSkinLauncher.Windows.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#F4F7FB" />
            <Setter Property="Background" Value="#24324A" />
            <Setter Property="BorderBrush" Value="#3A4B68" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,7" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#E8EDF5" />
            <Setter Property="Background" Value="#121C2E" />
            <Setter Property="BorderBrush" Value="#34435E" />
            <Setter Property="Padding" Value="8,6" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#162033" />
            <Setter Property="Background" Value="#E9EEF7" />
            <Setter Property="Padding" Value="7,5" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8EDF5" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,2,0,7" />
        </Style>
    </Application.Resources>
</Application>
